{
  "name": "ai-calendar",
  "version": "1.0.0",
  "description": "智能AI日历日志系统 - 支持多模型AI",
  "author": "AI Calendar",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "npx tsx server/index.ts",
    "build": "vite build",
    "build:server": "npx esbuild server/index.ts --bundle --platform=node --format=cjs --outfile=server/index.cjs --external:better-sqlite3",
    "start": "npx tsx server/index.ts",
    "electron": "electron .",
    "electron-build": "vite build && npm run build:server && npx @electron/rebuild -f -m . -v 43.0.0 && electron-builder --win portable --publish=never --config.electronDist=\"node_modules/electron/dist\" --config.electronVersion=\"43.0.0\"",
    "electron-dev": "concurrently \"vite build --watch\" \"electron .\"",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test --project=chromium"
  },
  "build": {
    "appId": "com.ai-calendar.app",
    "productName": "AI 智能日历",
    "npmRebuild": true,
    "directories": {
      "output": "release_v6"
    },
    "files": [
      "dist/**/*",
      "server/**/*.ts",
      "server/**/*.cjs",
      "server/**/*.js",
      "!server/*.db*",
      "shared/**/*",
      "public/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "logo.png",
        "to": "logo.png"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "icon": "logo.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "framer-motion": "^12.42.2",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.2"
  }
}
